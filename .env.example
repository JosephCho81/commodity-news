# .env.local (로컬 개발용 — .gitignore에 반드시 포함)
# Vercel 대시보드 → Settings → Environment Variables 에도 동일하게 추가

# ── Gemini API Key ─────────────────────────────────────────────────────────
# Google AI Studio (https://aistudio.google.com/app/apikey) 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# ── GitHub Actions용 Vercel 앱 URL ────────────────────────────────────────
# GitHub → 레포 Settings → Secrets → Actions → New repository secret
# Name: VERCEL_APP_URL
# Value: https://your-app-name.vercel.app  (trailing slash 없이)
# (이건 .env.local에는 필요 없고 GitHub Secrets에만 추가)

# ── Firebase는 firebase-applet-config.json 파일로 관리 ────────────────────
# 보안을 높이려면 아래처럼 환경변수로 분리 가능 (선택사항)
# FIREBASE_API_KEY=
# FIREBASE_PROJECT_ID=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
# FIRESTORE_DATABASE_ID=(default)

